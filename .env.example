# API Configuration
API_PORT=8080

# Database - when running everything inside docker
DATABASE_URL=postgres://candidate:password@postgres:5432/candidates?sslmode=disable

# Database - for running worker/api outside of docker
# DATABASE_URL=postgres://candidate:password@localhost:5432/candidates?sslmode=disable

# GCP Configuration
GCP_PROJECT=test-project
PUBSUB_TOPIC=candidate-applications

# For local development with emulator
PUBSUB_EMULATOR_HOST=localhost:8085

# Worker pool
WORKER_COUNT=10
WORKER_TIMEOUT_SECONDS=30
